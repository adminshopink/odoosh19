<odoo>
    <record id="view_form_move_inherited_binaural_advance_payment" model="ir.ui.view">
        <field name="name">account.move.binaural.advance.payment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <field name='invoice_outstanding_credits_debits_widget' position="after">
                <field name="invoice_outstanding_credits_debits_widget_advance_payment"
                    class="oe_invoice_outstanding_credits_debits" colspan="2" nolabel="1"
                    widget="payment" />
            </field>
            <xpath expr="//div[hasclass('d-flex')][2]" position="after">
                <field name="is_advance_move" invisible="1" />
                <field name="is_advance_move" readonly="1" invisible="not is_advance_move" />
                <field name="origin_payment_advanced_payment_id" readonly="1" />
            </xpath>


            <xpath expr="//div[hasclass('alert', 'alert-info')][1]" position="replace">
                <div groups="account.group_account_invoice,account.group_account_readonly"
                        class="alert alert-info" role="alert"
                        invisible="state != 'posted' or move_type not in ('out_invoice', 'out_receipt') or not invoice_has_outstanding or payment_state not in ('not_paid', 'partial')">
                    You have <bold><a class="alert-link" href="#outstanding" role="button" invisible="not invoice_outstanding_credits_debits_widget or invoice_outstanding_credits_debits_widget_advance_payment">outstanding credits</a>
                    <a class="alert-link" href="#outstanding" role="button" invisible="not invoice_outstanding_credits_debits_widget_advance_payment or invoice_outstanding_credits_debits_widget">advances</a>
                    <a class="alert-link" href="#outstanding" role="button" invisible="not (invoice_outstanding_credits_debits_widget_advance_payment and invoice_outstanding_credits_debits_widget)">outstanding credits and advances</a></bold> listed below for this customer.
                </div>
            </xpath>

            <xpath expr="//div[hasclass('alert', 'alert-info')][2]" position="replace">
                <div groups="account.group_account_invoice,account.group_account_readonly"
                         class="alert alert-info" role="alert"
                         invisible="state != 'posted' or move_type not in ('in_invoice', 'in_receipt') or not invoice_has_outstanding or payment_state not in ('not_paid', 'partial')">
                        You have <bold><a class="alert-link" href="#outstanding" role="button" invisible="not invoice_outstanding_credits_debits_widget or invoice_outstanding_credits_debits_widget_advance_payment">outstanding debits</a>
                        <a class="alert-link" href="#outstanding" role="button" invisible="not invoice_outstanding_credits_debits_widget_advance_payment or invoice_outstanding_credits_debits_widget">advances</a>
                        <a class="alert-link" href="#outstanding" role="button" invisible="not (invoice_outstanding_credits_debits_widget_advance_payment and invoice_outstanding_credits_debits_widget)">outstanding debits and advances</a></bold> listed below for this vendor.
                    </div>
            </xpath>

            <xpath expr="//div[hasclass('alert', 'alert-info')][3]" position="replace">
                <div groups="account.group_account_invoice,account.group_account_readonly"
                         class="alert alert-info" role="alert"
                         invisible="state != 'posted' or move_type != 'out_refund' or not invoice_has_outstanding or payment_state not in ('not_paid', 'partial')">
                        You have <bold><a class="alert-link" href="#outstanding" role="button" invisible="not invoice_outstanding_credits_debits_widget or invoice_outstanding_credits_debits_widget_advance_payment">outstanding debits</a>
                        <a class="alert-link" href="#outstanding" role="button" invisible="not invoice_outstanding_credits_debits_widget_advance_payment or invoice_outstanding_credits_debits_widget">advances</a>
                        <a class="alert-link" href="#outstanding" role="button" invisible="not (invoice_outstanding_credits_debits_widget_advance_payment and invoice_outstanding_credits_debits_widget)">outstanding debits and advances</a></bold> listed below for this customer.
                    </div>
            </xpath>
            <xpath expr="//div[hasclass('alert', 'alert-info')][3]" position="replace">
                <div groups="account.group_account_invoice,account.group_account_readonly"
                         class="alert alert-info" role="alert"
                         invisible="state != 'posted' or move_type != 'in_refund' or not invoice_has_outstanding or payment_state not in ('not_paid', 'partial')">
                        You have <bold><a class="alert-link" href="#outstanding" role="button" invisible="not invoice_outstanding_credits_debits_widget or invoice_outstanding_credits_debits_widget_advance_payment">outstanding credits</a>
                        <a class="alert-link" href="#outstanding" role="button" invisible="not invoice_outstanding_credits_debits_widget_advance_payment or invoice_outstanding_credits_debits_widget">advances</a>
                        <a class="alert-link" href="#outstanding" role="button" invisible="not (invoice_outstanding_credits_debits_widget_advance_payment and invoice_outstanding_credits_debits_widget)">outstanding credits and advances</a></bold> listed below for this vendor.
                    </div>
            </xpath>

        </field>
    </record>
</odoo>