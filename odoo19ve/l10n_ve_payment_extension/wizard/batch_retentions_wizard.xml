<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_batch_retentions_wizard_form" model="ir.ui.view">
        <field name="name">batch.retentions.wizard.form</field>
        <field name="model">batch.retentions.wizard</field>
        <field name="arch" type="xml">
            <form string="Batch Retentions">
                <sheet>

                    <field name="has_payed_invoices" invisible="1"/>
                    <field name="has_draft_cancel_invoices" invisible="1"/>
                    <field name="has_not_allow_retentions_islr_invoices" invisible="1"/>

                    <div class="alert alert-warning" role="alert"
                       invisible="not has_payed_invoices">
                        Emited withholdings for paid invoices will remain as outstanding credits.
                    </div>

                    <div class="alert alert-warning" role="alert"
                        invisible="not has_draft_cancel_invoices">
                       Draft or cancel moves will not be considerer in this operation.
                    </div>

                     <div class="alert alert-danger" role="alert"
                        invisible="not has_not_allow_retentions_islr_invoices">
                        There are some invoices that are not allow ISLR Retention
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field
                                name="name"
                                readonly="1"
                            />
                            <field name="type_retention" invisible="1"/>
                        </h1>

                        
                    </div>
                    <group id="settings">
                        <field name="group_retentions" />
                    </group>

                    

                    <notebook>
                        <field name="line_ids" invisible="1" />
                        <page string="Valid invoices for retentions" name="valid_invoices" invisible="not valid_line_ids">
                            
                            <field name="valid_line_ids" nolabel="1" style="pointer-events:none;">
                                <list create="0" delete="0" open_form_view="0" decoration-success="1">
                                    <field name="wizard_id" column_invisible="True" />
                                    <field name="move_id" readonly="1" />
                                    <field name="partner_id" widget="many2one_avatar_user" readonly="1" />
                                    <field name="is_isrl_retention_available" widget="boolean_toggle" readonly="1" />
                                    
                                    <field name="has_emited_islr_retention" widget="boolean_toggle" column_invisible="True" readonly="1" />
                                    <field name="count_islr_retention" readonly="1" />
                                    <field name="state" widget="badge" 
                                           decoration-success="state == 'posted'"
                                           readonly="1" />
                                    <field name="payment_state" widget="badge" 
                                           decoration-info="payment_state in ['paid','partial']" 
                                           decoration-warning="payment_state == 'in_payment'"
                                           decoration-success="payment_state == 'not_paid'"
                                           readonly="1" />
                                    <field name="post_retention" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>

                        <page string="Not valid invoices for retentions" name="invalid_invoices" invisible="not invalid_line_ids">
                            <field name="invalid_line_ids" nolabel="1" style="pointer-events:none;">
                                <list create="0" edit="1" editable="bottom"  open_form_view="0" decoration-danger="1">
                                    <field name="move_id" readonly="1" />
                                    <field name="wizard_id" column_invisible="True" />
                                    <field name="partner_id" widget="many2one_avatar_user" readonly="1" />
                                    <field name="is_isrl_retention_available" widget="boolean_toggle" readonly="1" column_invisible="True"/>
                                    
                                    <field name="has_emited_islr_retention" widget="boolean_toggle" column_invisible="True" readonly="1" />
                                    <field name="count_islr_retention" readonly="1" />
                                    <field name="state" widget="badge" 
                                           decoration-danger="state in ['draft','cancel']" 
                                           decoration-success="state == 'posted'"
                                           readonly="1" />
                                    <field name="payment_state" widget="badge" 
                                           decoration-info="payment_state in ['paid','partial']" 
                                           decoration-warning="payment_state == 'in_payment'"
                                           decoration-success="payment_state == 'not_paid'"
                                           readonly="1" />
                                    <field name="post_retention" widget="boolean_toggle"  column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    
                </sheet>
                <footer>
                    <button name="create_muti_retencion" string="Process Retentions" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_batch_retentions_wizard_lines_tree" model="ir.ui.view">
        <field name="name">batch.retentions.wizard.lines.list</field>
        <field name="model">batch.retentions.wizard.lines</field>
        <field name="arch" type="xml">
            <list>
                
                <field name="post_retention" />
                
                <field name="move_id" />
                <field name="partner_id" />
                
                <field name="is_isrl_retention_available" />
                <field name="count_islr_retention"/>
                
                <field name="state" />
                
                <field name="payment_state" />

                <field name="has_emited_islr_retention" />
            </list>
        </field>
    </record>

    <record id="action_batch_retentions_wizard" model="ir.actions.act_window">
        <field name="name">ISLR Retention</field>
        <field name="res_model">batch.retentions.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>