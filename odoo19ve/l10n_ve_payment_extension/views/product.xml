<odoo>
    <record id="product_normal_form_view" model="ir.ui.view">
        <field name="name">product.l10n.ve.extend.ciu</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
	    <notebook position="inside">
		<page name="ciu_ids" string="Economic Activities">
		    <field name="ciu_ids" options="{'no_create': True}"/>
		</page>
	    </notebook>

        <xpath expr="//field[@name='property_account_expense_id']" position="after">
            <field name="payment_concept" invisible="type != 'service'"/>
            <field name="type" invisible="1"/>
        </xpath>
        </field>
    </record>

    
</odoo>
