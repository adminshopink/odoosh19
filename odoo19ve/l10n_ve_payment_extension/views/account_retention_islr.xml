<odoo>

    <data>


        <record id="view_retention_islr_form_l10n_ve_payment_extension" model="ir.ui.view">
            <field name="name">Retention ISLR client form</field>
            <field name="model">account.retention</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Retention" duplicate="false">
                    <header>
                        <button name="action_draft" type="object"
                            string="Convert to draft"
                            invisible="type != 'out_invoice' or state != 'cancel'" />
                        <button name="action_post" type="object" invisible="state != 'draft'" string="Approve"
                            class="oe_highlight" />
                        <button name="action_cancel" type="object" invisible="state != 'emitted'" string="Cancel"
                            confirm="Are you sure you want to cancel this voucher? The associated accounting entries will be reversed" />
                        <field name="state" widget="statusbar" nolabel="1" />
                    </header>
                    <sheet>
                        <group colspan="4" col="4">
                            <!-- Invisible fields -->
                            <field name="name" invisible="1" force_save="1" />
                            <field name="available_invoice_ids" invisible="1" />
                            <field name="actual_invoice_ids" invisible="1" />
                            <field name="base_currency_is_vef" invisible="1" />
                            <field name="company_currency_id" invisible="1" />
                            <field name="foreign_currency_id" invisible="1" />
                            <field name="allowed_lines_move_ids" invisible="1" />
                            <field name="code_visible" invisible="1" />
                            <field name="type" force_save="1" select="2" />
                            <field name="type_retention" force_save="1" select="2" invisible="1" />
                            <field name="is_third_party_retention" readonly="1" invisible="type != 'in_invoice'"/>
                            <field name="partner_id" on_change="onchange_partner_id(type,partner_id)"
                                select="1"
                                invisible="not type"
                                readonly="state in ['emitted', 'cancel']" />
                            <field name="date_accounting" select="1"
                                readonly="state in ['emitted', 'cancel']" required='1' />
                            <field name="number" force_save="1"
                                readonly="type == 'in_invoice' or state in ['emitted', 'cancel']"
                                required="type == 'out_invoice'" />
                            <field name="correlative" force_save="1"
                                invisible="1"
                                readonly="type == 'in_invoice'" />
                            <field name="date"
                                readonly="type == 'in_invoice' or state in ['emitted', 'cancel']" />
                        </group>
                        <notebook colspan="4">
                            <page name="retention_lines" string="Retention Lines">
                                <field colspan="4" name="retention_line_ids" nolabel="1"
                                    invisible="not partner_id"
                                    readonly="state in ['emitted', 'cancel']">
                                    <list editable="bottom">
                                        <field name="company_currency_id" column_invisible="True" />
                                        <field name="foreign_currency_id" column_invisible="True" />
                                        <field name="name" required="1" readonly="1" force_save="1" />
                                        <field
                                            name="move_id"
                                            options="{'no_create': True}"
                                            force_save="1"
                                            domain="[('id', 'in', parent.allowed_lines_move_ids), ('islr_voucher_number', '=',False)]"
                                        />
                                        <field name="code"
                                            column_invisible="not parent.code_visible" />
                                        <field name="company_id" optional="hide"
                                            groups="base.group_multi_company" />
                                        <field name="allowed_payment_concept_ids" column_invisible="True"/>
                                        <field name="payment_concept_id" 
                                            column_invisible="parent.type_retention != 'islr'"
                                            domain="[('id', 'in', allowed_payment_concept_ids)]"
                                            force_save="1" 
                                            readonly="not move_id"/>
                                        <field name="is_retention_client" column_invisible="True" />
                                        <field
                                            name="invoice_total"
                                            force_save="1"
                                            string="Invoice Total"
                                            widget="monetary"
                                            options="{'currency_field': 'company_currency_id'}"
                                            readonly="1"
                                            column_invisible="not parent.base_currency_is_vef"/>
                                        <field
                                            name="foreign_invoice_total"
                                            force_save="1"
                                            string="Invoice Total"
                                            widget="monetary"
                                            options="{'currency_field': 'foreign_currency_id'}"
                                            readonly="1"
                                            column_invisible="parent.base_currency_is_vef"/>
                                        <field
                                            name="invoice_amount"
                                            force_save="1"
                                            string="Invoice Amount"
                                            widget="monetary"
                                            options="{'currency_field': 'company_currency_id'}"
                                            column_invisible="not parent.base_currency_is_vef"/>

                                        <field
                                            name="foreign_invoice_amount"
                                            force_save="1"
                                            string="Invoice Amount"
                                            widget="monetary"
                                            options="{'currency_field': 'foreign_currency_id'}"
                                            column_invisible="parent.base_currency_is_vef"/>

                                        <field
                                            name="related_pay_from"
                                            force_save="1"
                                            readonly="1"
                                            column_invisible="parent.type == 'out_invoice' or parent.type_retention != 'islr'"/>
                                        <field
                                            name="related_percentage_tax_base"
                                            force_save="1"
                                            readonly="1"
                                        />
                                        <field
                                            name="related_percentage_fees"
                                            force_save="1"
                                            readonly="1"
                                            column_invisible="parent.type_retention != 'islr'"
                                        />
                                        <field
                                            name="related_amount_subtract_fees"
                                            force_save="1"
                                            readonly="1"
                                            column_invisible="parent.type_retention != 'islr'"
                                        />
                                        <field
                                            name="foreign_currency_rate"
                                            force_save="1"
                                            readonly="1"
                                            optional="hide"
                                        />
                                        <field
                                            name="retention_amount"
                                            force_save="1"
                                            widget="monetary"
                                            options="{'currency_field': 'company_currency_id'}"
                                            column_invisible="not parent.base_currency_is_vef"
                                            readonly="parent.type == 'in_invoice'"/>
                                        <field
                                            name="foreign_retention_amount"
                                            force_save="1"
                                            widget="monetary"
                                            options="{'currency_field': 'foreign_currency_id'}"
                                            column_invisible="parent.base_currency_is_vef"
                                            readonly="parent.type == 'in_invoice'"/>
                                    </list>
                                </field>

                                <group col="2" colspan="2"
                                    invisible="not base_currency_is_vef">
                                    <field
                                        name="total_invoice_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'company_currency_id'}"
                                    />
                                    <field
                                        name="total_retention_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'company_currency_id'}"
                                    />
                                </group>

                                <group col="2" colspan="2"
                                    invisible="base_currency_is_vef">
                                    <field
                                        name="foreign_total_invoice_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'foreign_currency_id'}"
                                    />
                                    <field
                                        name="foreign_total_retention_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'foreign_currency_id'}"
                                    />
                                </group>
                            </page>
                            <page name="Payments" string="payments">
                                <field name="payment_ids" nolabel="1" readonly="1" force_save="1">
                                    <kanban class="o_kanban_mobile" sample="1" quick_create="false" can_open="False">
                                        <field name="id"/>
                                        <field name="name"/>
                                        <field name="date"/>
                                        <field name="amount"/>
                                        <field name="state"/>
                                        <field name="payment_type_retention"/>
                                        <field name="currency_id"/>
                                        
                                        <templates>
                                            <t t-name="card" class="flex-row align-items-center p-3 gap-3 border-bottom">
                                                <div class="oe_kanban_card flex-grow-1 d-flex align-items-center justify-content-between">
                                                    <div class="d-flex flex-column align-items-start gap-1" style="min-width: 0; flex: 1;">
                                                        <div class="d-flex flex-wrap align-items-center gap-2 w-100">
                                                          
                                                            <span class="fw-bold text-dark" style="max-width: 180px;" t-att-title="record.name.value">
                                                                <t t-out="record.name.value"/>
                                                            </span>
                                                        </div>
                                                        
                                                        <small class="text-muted d-flex align-items-center mt-1">
                                                            <i class="fa fa-calendar me-1" title="Date"/>
                                                            <t t-out="record.date.value"/>
                                                        </small>

                                                         <small class="badge bg-secondary-subtle text-secondary border border-secondary-subtle text-uppercase fw-bold px-2" style="font-size: 0.75rem;">
                                                                <t t-out="record.payment_type_retention.value"/>
                                                        </small>
                                                        
                                                    </div>

                                                    <div class="d-flex align-items-center gap-4">
                                                        <div class="text-end">
                                                            <div class="fw-bold text-dark fs-5">
                                                                <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                                            </div>
                                                            <span t-attf-class="badge rounded-pill #{record.state.raw_value == 'posted' ? 'text-bg-success' : 'text-bg-info'}">
                                                                <field name="state"/>
                                                            </span>
                                                        </div>

                                                        <button name="action_open_business_doc" 
                                                                type="object" 
                                                                class="btn btn-outline-primary d-flex align-items-center gap-1">
                                                            <span>Show</span>
                                                        </button>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_retention_islr_client" model="ir.actions.act_window">
            <field name="name">ISLR Retention client</field>
            <field name="res_model">account.retention</field>
            <field name="binding_view_types">list</field>
            <field name="view_mode">list,form</field>
            <!--field
            name="search_view_id" ref="view_search_retention_iva"/-->
            <field name="context">{"default_type":'out_invoice', "default_type_retention":'islr'}</field>
            <field name="domain">[('type_retention', '=', 'islr'), ('type', '=', 'out_invoice')]</field>
        </record>

        <!--Configuracion
        de Vista: Retenciones ISLR Proveedor-->
        <record id="action_retention_islr_supplier" model="ir.actions.act_window">
            <field name="name">ISLR Retention supplier</field>
            <field name="res_model">account.retention</field>
            <field name="binding_view_types">list</field>
            <field name="view_mode">list,form</field>
            <!--field
            name="search_view_id" ref="view_search_retention_iva"/-->
            <field name="context">{"default_type":'in_invoice', "default_type_retention":'islr'}</field>
            <field name="domain">[('type_retention', '=', 'islr'), ('type', '=', 'in_invoice')]</field>
        </record>


    </data>


</odoo>
