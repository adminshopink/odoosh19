<odoo>
    <data>
        <record id="view_tax_unit_list_inherit_l10n_ve" model="ir.ui.view">
            <field name="name">view.tax.unit.list.inherit.l10n.ve</field>
            <field name="model">tax.unit</field>
            <field name="inherit_id" ref="l10n_ve_accountant.view_tax_unit_tree_l10n_ve_payment_extension"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="decoration-success">status == True</attribute>
                </xpath>
                <xpath expr="//field[@name='name']" position="before">
                    <field name="available_date" />
                </xpath>
                <xpath expr="//field[@name='status']" position="attributes">
                    <attribute name="widget">boolean_toggle</attribute>
                    <attribute name="readonly">1</attribute>
                    <attribute name="force_save">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_tax_unit_form_inherit_l10n_ve" model="ir.ui.view">
            <field name="name">view.tax.unit.form.inherit.l10n.ve</field>
            <field name="model">tax.unit</field>
            <field name="inherit_id" ref="l10n_ve_accountant.view_tax_unit_form_l10n_ve_payment_extension"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="available_date" />
                </xpath>
                <xpath expr="//field[@name='status']" position="attributes">
                    <attribute name="widget">boolean_toggle</attribute>
                    <attribute name="readonly">1</attribute>
                    <attribute name="force_save">1</attribute>
                </xpath>
            </field>
        </record>

   
    </data>
</odoo>