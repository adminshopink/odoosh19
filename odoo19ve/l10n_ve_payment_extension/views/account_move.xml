<odoo>
    <data>
        <record id="account_move_form_l10n_ve_payment_extension" model="ir.ui.view">
            <field name="name">account.move.form.l10n.ve.payment.extension</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <field name="is_isrl_retention_available" invisible="1"/>
                    <field name="has_emited_islr_retention" invisible="1"/>
                    <field name="has_emited_iva_retention" invisible="1"/>
                    <field name="has_emited_municipal_retention" invisible="1"/>

                    <button name="action_view_retention" 
                            type="object"
                            class="oe_stat_button"
                            context="{'retention_type': 'islr'}"
                            invisible="count_islr_retention == 0"
                            decoration-success="has_emited_islr_retention"
                            decoration-warning="not has_emited_islr_retention">
                        
                        <i class="fa fa-check-circle text-success" 
                        title="Retencion islr"
                        aria-label="Retención islr"
                        invisible="not has_emited_islr_retention" 
                        style="font-size: 1.5em; margin-left: 10px; margin-right: 5px;"/>
                        
                        <i class="fa fa-exclamation-circle text-warning" 
                        title="Retención islr w"
                        aria-label="Retencion islr w"
                        invisible="has_emited_islr_retention" 
                        style="font-size: 1.5em; margin-left: 10px; margin-right: 5px;"/>

                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="count_islr_retention"/>
                            </span>
                            <span class="o_stat_text">Retencion ISLR</span>
                        </div>
                    </button>

                    <button name="action_view_retention" 
                            type="object"
                            class="oe_stat_button"
                            context="{'retention_type': 'iva'}"
                            invisible="count_iva_retention == 0"
                            decoration-success="has_emited_iva_retention"
                            decoration-warning="not has_emited_iva_retention">
                        
                        <i class="fa fa-check-circle text-success" 
                        invisible="not has_emited_iva_retention" 
                        title="Retención iva"
                        aria-label="Retención iva"
                        style="font-size: 1.5em; margin-left: 10px; margin-right: 5px;"/>
                        
                        <i class="fa fa-exclamation-circle text-warning" 
                        invisible="has_emited_iva_retention" 
                        title="Retención iva w"
                        aria-label="Retención iva w"
                        style="font-size: 1.5em; margin-left: 10px; margin-right: 5px;"/>

                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="count_iva_retention"/>
                            </span>
                            <span class="o_stat_text">Retencion IVA</span>
                        </div>
                    </button>

                    <button name="action_view_retention" 
                            type="object"
                            class="oe_stat_button"
                            context="{'retention_type': 'municipal'}"
                            invisible="count_municipal_retention == 0"
                            decoration-success="has_emited_municipal_retention"
                            decoration-warning="not has_emited_municipal_retention">
                        
                        <i class="fa fa-check-circle text-success" 
                        title="Retención municipal"
                        aria-label="Retención municipal"
                        invisible="not has_emited_municipal_retention" 
                        style="font-size: 1.5em; margin-left: 10px; margin-right: 5px;"/>
                        
                        <i class="fa fa-exclamation-circle text-warning" 
                        title="Retención municipal w"
                        aria-label="Retención municipal w"
                        invisible="has_emited_municipal_retention" 
                        style="font-size: 1.5em; margin-left: 10px; margin-right: 5px;"/>

                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="count_municipal_retention"/>
                            </span>
                            <span class="o_stat_text">Retencion Municipal</span>
                        </div>
                    </button>

                </xpath>

                <xpath expr="//header" position="after">
                    <field name="count_islr_retention" invisible="1"/>
                    <field name="has_emited_islr_retention" invisible="1"/>
                    <div class="alert alert-warning" role="alert"
                         invisible="(count_islr_retention > 0 and has_emited_islr_retention) or count_islr_retention == 0">
                        Warning: You have ISLR retentions to aproved
                    </div>
                </xpath>

                <xpath expr="//field[@name='partner_shipping_id']" position="after">

                    <field name="base_currency_is_vef" invisible="1"/>
                    <field name="company_currency_id" invisible="1"/>
                    <field name="foreign_currency_id" invisible="1"/>
                    <field name="not_edit_islr_retention_lines" invisible="1"/>
                    <field name="not_edit_municipal_retention_lines" invisible="1"/>

                    <field
                        name="generate_iva_retention" readonly="state == 'posted'"
                    />
                    <field
                        name="is_isrl_retention_available" invisible="1" force_save="1"
                    />
                    <field
                        name="generate_islr_retention" invisible="not is_isrl_retention_available" readonly="state == 'posted'"
                    />
                    <field
                        name="is_third_party_retention"
                        string="Third Party Billing"
                        invisible="move_type not in ('in_invoice', 'in_receipt', 'in_refund')" readonly="state == 'posted'"
                    />
                    <field name="iva_voucher_number" readonly="1" invisible="not iva_voucher_number" force_save="1"/>
                    <field name="islr_voucher_number" readonly="1" invisible="not islr_voucher_number" force_save="1"/>
                    <field name="municipal_voucher_number" readonly="1" invisible="not municipal_voucher_number" force_save="1"/>

                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button
                        name="action_view_third_party_iva_retentions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-balance-scale"
                        invisible="not is_third_party_retention or move_type not in ('in_invoice', 'in_receipt', 'in_refund')"
                    >
                        <field name="third_party_iva_retention_count" widget="statinfo" string="Third Party IVA Ret."/>
                    </button>
                    <button
                        name="action_view_third_party_islr_retentions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-university"
                        invisible="not is_third_party_retention or move_type not in ('in_invoice', 'in_receipt', 'in_refund')"
                    >
                        <field name="third_party_islr_retention_count" widget="statinfo" string="Third Party ISLR Ret."/>
                    </button>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <field name="count_iva_retention" invisible="1"/>
                    <field name="count_islr_retention" invisible="1"/>
                    <field name="count_municipal_retention" invisible="1"/>
                    <page name="iva_retention" string="IVA Retentions" invisible="count_iva_retention == 0">
                        
                        <field name="retention_iva_line_ids" 
                        nolabel="1" 
                        readonly="1" 
                        >
                            <list editable='bottom'>
                                <!-- Invisible Fields -->
                                <field name="invoice_type" column_invisible="True"/>
                                <field name="company_currency_id" column_invisible="True"/>
                                <field name="foreign_currency_id" column_invisible="True"/>
                                <field name="name"/>
                                <field name="move_id"/>
                                <field name="aliquot"/>
                                <field name="related_percentage_tax_base" optional="hide"/>
                                <!-- Amounts -->
                                <field
                                    name="invoice_total"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="invoice_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="iva_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="retention_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <!-- Foreign Amounts -->
                                <field
                                    name="foreign_invoice_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_iva_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_total"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_retention_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field name="foreign_currency_rate" optional="hide"/>
                                <field name="state"/>
                            </list>
                        </field>
                    </page>
                    <page name="islr_retention" string="ISLR Retentions" invisible="count_islr_retention == 0">
                        
                        <field
                            name="retention_islr_line_ids"
                            nolabel="1"
                            readonly="1">
                            <list editable='bottom'>
                                <!-- Invisible Fields -->
                                <field name="invoice_type" column_invisible="True"/>
                                <field name="company_currency_id" column_invisible="True"/>
                                <field name="foreign_currency_id" column_invisible="True"/>
                                <field name="name"/>
                                <field name="payment_concept_id"/>
                                <field
                                    name="invoice_total"
                                    readonly="1"
                                    force_save="1"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_total"
                                    force_save="1"
                                    readonly="1"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="invoice_amount"
                                    force_save="1"
                                    string="Invoice Amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_amount"
                                    force_save="1"
                                    string="Invoice Amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field name="related_pay_from" force_save="1" readonly="1"/>
                                <field name="related_percentage_tax_base" force_save="1" readonly="1"/>
                                <field name="related_percentage_fees" force_save="1" readonly="1"/>
                                <field name="related_amount_subtract_fees" force_save="1" readonly="1"/>
                                <field name="foreign_currency_rate" force_save="1" readonly="1" optional="hide"/>
                                <field
                                    name="retention_amount"
                                    readonly="1"
                                    force_save="1"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_retention_amount"
                                    widget="monetary"
                                    force_save="1"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field name="state"/>
                            </list>
                        </field>
                    </page>
                    <page name="municipal_retention" string="Municipal Retentions" invisible="count_municipal_retention == 0">
                        
                        <field
                            name="retention_municipal_line_ids"
                            nolabel="1"
                            readonly="1"
                            >
                            <list editable='bottom'>
                                <field name="name" force_save="1" readonly="1"/>
                                <field name="economic_activity_id" force_save="1"/>
                                <field name="aliquot" readonly="1" force_save="1"/>
                                <field
                                    name="invoice_amount"
                                    force_save="1"
                                    string="Invoice Amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="invoice_total"
                                    readonly="1"
                                    force_save="1"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="retention_amount"
                                    readonly="1"
                                    force_save="1"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_amount"
                                    force_save="1"
                                    string="Invoice Amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_total"
                                    force_save="1"
                                    readonly="1"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_retention_amount"
                                    widget="monetary"
                                    force_save="1"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field name="foreign_currency_rate" force_save="1" readonly="1" optional="hide"/>
                                <field name="state" force_save="1"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
