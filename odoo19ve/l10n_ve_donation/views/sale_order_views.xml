<odoo>
    <record id="view_order_form_l10n_ve_donation" model="ir.ui.view">
        <field name="name">sale.order.form.l10n.ve.donation</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="l10n_ve_sale.view_sale_order_form_l10n_ve_sales" />
        <field name="arch" type="xml">
            <field name="manually_set_rate" position="after">
                <field name="is_donation" readonly="state in ['sale', 'done', 'cancel']" force_save="1"/>
            </field>
        </field>
    </record>
</odoo>
